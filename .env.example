# ── Database ──────────────────────────────────────────────
POSTGRES_USER=mlplatform
POSTGRES_PASSWORD=mlplatform_secret
POSTGRES_DB=mlplatform
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mlplatform:mlplatform_secret@db:5432/mlplatform

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Admin credentials (single-user mode) ─────────────────
ADMIN_EMAIL=admin@mlplatform.dev
ADMIN_PASSWORD=admin_secret

# ── Storage ───────────────────────────────────────────────
ARTIFACT_STORE_PATH=/app/artifacts

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
